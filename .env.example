# =============================================================================
# AEGIS Environment Variables — Template
# Copy to .env and fill in real values
# NEVER commit .env to git
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Routed through PgBouncer (aegis_pooled_role is a static LOGIN role granted
# aegis_app_role — see migration 008; there is no direct-to-primary static
# login role, migration 004 only creates the non-login aegis_app_role group)
POSTGRES_HOST=aegis-pgbouncer
POSTGRES_PORT=6432
POSTGRES_DB=aegis
POSTGRES_USER=aegis_pooled_role
POSTGRES_PASSWORD=REPLACE_strong_password

# ─── Qdrant Vector Database ───────────────────────────────────────────────────
# Collections: meridian_errors, meridian_procedures, meridian_configs, cache_queries
# All vectors: 768-dimensional (BGE-base-en-v1.5)
QDRANT_HOST=aegis-qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── OpenSearch (BM25 keyword search) ─────────────────────────────────────────
OPENSEARCH_HOST=aegis-opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=REPLACE_strong_password
OPENSEARCH_INDEX=sap_documents

# ─── Redis (TWO separate instances) ──────────────────────────────────────────
# Instance 1: session store, semantic cache, rate limiting
REDIS_SESSION_URL=redis://aegis-redis-session:6379
# Instance 2: ARQ job queue, JWT revocation set
REDIS_QUEUE_URL=redis://aegis-redis-queue:6379

# ─── MinIO Object Storage ─────────────────────────────────────────────────────
MINIO_ENDPOINT=aegis-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=REPLACE_strong_password
MINIO_BUCKET_DOCUMENTS=aegis-documents
MINIO_BUCKET_SCREENSHOTS=knowledge-screenshots
MINIO_USE_SSL=false
# Required for minio-py SDK signature compatibility even against a non-AWS
# endpoint — us-east-1 is a placeholder with no geographic meaning here.
MINIO_REGION=us-east-1

# ─── Keycloak OIDC ────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://aegis-keycloak:8080
KEYCLOAK_REALM=aegis-realm
KEYCLOAK_CLIENT_ID=aegis-chat
KEYCLOAK_CLIENT_SECRET=REPLACE_client_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_keycloak_admin_password

# ─── HashiCorp Vault ──────────────────────────────────────────────────────────
VAULT_ADDR=http://aegis-vault:8200
VAULT_ROLE_ID=REPLACE_role_id
VAULT_SECRET_ID=REPLACE_secret_id
# Dev only — do not use in production
VAULT_DEV_ROOT_TOKEN=aegis-dev-root-token

# ─── AI Models — INFERENCE_MODE controls routing (see CLAUDE.md Rule 5) ───────
# external (default): Cerebras primary / Groq fallback for main+judge,
#                      Groq primary / Cerebras fallback for vision. No local
#                      containers required — the 3 Ollama services below stay
#                      stopped unless you run with --profile local-inference.
# local: routes through the Ollama containers instead. Requires
#        `docker compose --profile local-inference up -d`.
INFERENCE_MODE=external

CEREBRAS_API_KEY=REPLACE_your_cerebras_api_key
GROQ_API_KEY=REPLACE_your_groq_api_key
SAMBANOVA_API_KEY=REPLACE_your_sambanova_api_key
CLOUDFLARE_ACCOUNT_ID=REPLACE_your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=REPLACE_your_cloudflare_api_token
GEMINI_API_KEY=REPLACE_your_gemini_api_key

# The following are hardcoded in config.py (not environment-driven) since
# they are architectural choices, not per-deployment secrets — listed here
# for reference only, do not duplicate as env vars:
#   CEREBRAS_BASE_URL, CEREBRAS_MODEL_MAIN, CEREBRAS_MODEL_VISION
#   GROQ_BASE_URL, GROQ_MODEL_MAIN, GROQ_MODEL_JUDGE, GROQ_MODEL_VISION
#   SAMBANOVA_BASE_URL, SAMBANOVA_MODEL_MAIN, SAMBANOVA_MODEL_JUDGE
#   CLOUDFLARE_BASE_URL (built from CLOUDFLARE_ACCOUNT_ID), CLOUDFLARE_MODEL_MAIN,
#     CLOUDFLARE_MODEL_JUDGE, CLOUDFLARE_MODEL_VISION, CLOUDFLARE_MODEL_VISION_2
#   GEMINI_BASE_URL, GEMINI_MODEL_VISION

# ─── AI Models — LOCAL (only used when INFERENCE_MODE=local) ──────────────────
OLLAMA_MAIN_URL=http://aegis-ollama-main:11434
OLLAMA_JUDGE_URL=http://aegis-ollama-judge:11434
OLLAMA_VISION_URL=http://aegis-ollama-vision:11434
OLLAMA_MODEL_MAIN=qwen2.5:32b
OLLAMA_MODEL_JUDGE=qwen2.5:7b
OLLAMA_MODEL_VISION=qwen2.5vl:7b

# ─── AI Microservices (internal Docker network) ────────────────────────────────
BGE_SERVICE_URL=http://aegis-bge:8002
DEBERTA_SERVICE_URL=http://aegis-deberta:8001

# ─── Semantic Cache ───────────────────────────────────────────────────────────
SEMANTIC_CACHE_THRESHOLD=0.88
SEMANTIC_CACHE_TTL_HOURS=24

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
BACKEND_INTERNAL_URL=http://aegis-fastapi:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=REPLACE_generate_with_openssl_rand_base64_32
